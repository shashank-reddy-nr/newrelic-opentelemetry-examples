# ============================================================
# New Relic OpenTelemetry - Kafka Monitoring Example
# Copy this file to .env and fill in your values
# ============================================================

# ── Required ────────────────────────────────────────────────
# Your New Relic license key (ingest key)
# Find it at: https://one.newrelic.com/admin-portal/api-keys/home
NEW_RELIC_LICENSE_KEY=YOUR_LICENSE_KEY_HERE

# ── New Relic Endpoint ──────────────────────────────────────
# US accounts (default):
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net:4317
# EU accounts:
# NEW_RELIC_OTLP_ENDPOINT=https://otlp.eu01.nr-data.net:4317

# Kafka Cluster Identity ────────────────────────
# Name used to identify this cluster in New Relic
# All metrics will include kafka.cluster.name=<this value>
KAFKA_CLUSTER_NAME=kafka-selfhost-cluster

# Name that appears for producer in New Relic service maps
PRODUCER_SERVICE_NAME=kafka-producer

# Name that appears for consumer in New Relic service maps
CONSUMER_SERVICE_NAME=kafka-consumer

# Kafka consumer group ID (used for consumer lag metrics)
CONSUMER_GROUP_ID=nr-otel-consumer-group


# ── OTel Collector Image ────────────────────────────────────
# NRDOT is New Relic's OTel Collector distribution — same components as
# otelcol-contrib with full New Relic support. Swap the lines below to
# use the upstream collector instead.
OTEL_COLLECTOR_IMAGE=newrelic/nrdot-collector:latest
# OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:latest

# ── Optional: Broker Metric Export ─────────────────────────
# How often each broker's OTel Java Agent exports JMX metrics (milliseconds)
BROKER_METRIC_EXPORT_INTERVAL_MS=30000

# How often the kafkametrics receiver scrapes consumer lag / topic / broker metrics
KAFKA_METRICS_COLLECTION_INTERVAL=30s

# ── Optional: Application Settings ─────────────────────────
# How often the producer sends messages (milliseconds)
MESSAGE_INTERVAL_MS=200


